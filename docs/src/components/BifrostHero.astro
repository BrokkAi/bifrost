---
import { LinkButton } from '@astrojs/starlight/components';
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

const { data } = (Astro.locals as { starlightRoute: StarlightRouteData }).starlightRoute.entry;
const { actions = [] } = data.hero || {};

const contours = [
	'M 60 416 C 210 356, 350 385, 468 344 S 704 315, 890 360',
	'M 16 450 C 204 386, 348 423, 490 375 S 733 348, 930 396',
	'M -30 488 C 174 424, 358 457, 508 410 S 755 384, 970 432',
	'M -60 528 C 174 462, 364 500, 528 452 S 795 425, 1000 476',
	'M -90 570 C 138 506, 370 540, 548 494 S 820 470, 1030 522',
	'M -120 614 C 126 548, 378 586, 568 538 S 850 514, 1060 568',
];

const rays = [
	'M 455 338 C 396 420, 280 526, 158 640',
	'M 477 338 C 446 430, 382 536, 316 640',
	'M 501 337 C 492 432, 474 538, 456 640',
	'M 527 337 C 540 428, 568 535, 600 640',
	'M 553 338 C 590 426, 658 530, 738 640',
	'M 580 340 C 644 420, 758 522, 886 640',
	'M 425 342 C 326 414, 152 515, -18 610',
	'M 610 344 C 704 414, 848 496, 990 574',
];

const nodes = [
	{ x: 217, y: 413, kind: 'quiet' },
	{ x: 357, y: 413, kind: 'hot' },
	{ x: 487, y: 376, kind: 'quiet' },
	{ x: 650, y: 365, kind: 'hot' },
	{ x: 783, y: 405, kind: 'quiet' },
	{ x: 182, y: 511, kind: 'hot' },
	{ x: 477, y: 500, kind: 'quiet' },
	{ x: 701, y: 485, kind: 'quiet' },
	{ x: 847, y: 520, kind: 'hot' },
];
---

<section class="bifrost-hero" aria-labelledby="_top">
	<div class="terrain-wrap" aria-hidden="true">
		<div class="terrain-halo"></div>
		<svg class="semantic-terrain" viewBox="0 0 920 640" preserveAspectRatio="xMidYMax slice">
			<defs>
				<linearGradient id="terrain-stroke" x1="0" y1="0" x2="1" y2="0">
					<stop offset="0" stop-color="#eb3f33" stop-opacity="0" />
					<stop offset="0.24" stop-color="#eb3f33" stop-opacity="0.38" />
					<stop offset="0.58" stop-color="#f4f1ec" stop-opacity="0.28" />
					<stop offset="1" stop-color="#eb3f33" stop-opacity="0" />
				</linearGradient>
				<radialGradient id="node-fill">
					<stop offset="0" stop-color="#fff5ee" />
					<stop offset="0.28" stop-color="#ff6a5f" />
					<stop offset="1" stop-color="#eb3f33" stop-opacity="0" />
				</radialGradient>
				<filter id="terrain-glow" x="-100%" y="-100%" width="300%" height="300%">
					<feGaussianBlur stdDeviation="4" result="blur" />
					<feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
				</filter>
				<mask id="terrain-fade">
					<linearGradient id="fade-gradient" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0" stop-color="black" />
						<stop offset="0.5" stop-color="white" />
						<stop offset="1" stop-color="white" />
					</linearGradient>
					<rect width="920" height="640" fill="url(#fade-gradient)" />
				</mask>
			</defs>

			<g class="terrain-mesh" mask="url(#terrain-fade)" fill="none" stroke="url(#terrain-stroke)">
				{contours.map((d, index) => <path d={d} style={`--line-index:${index}`} />)}
				{rays.map((d, index) => <path class="terrain-ray" d={d} style={`--line-index:${index}`} />)}
			</g>

			<path
				class="analysis-route"
				d="M 182 511 C 245 467, 294 446, 357 413 S 550 386, 650 365 S 758 431, 847 520"
				fill="none"
				stroke="#ff6a5f"
				stroke-width="2"
				stroke-linecap="round"
				filter="url(#terrain-glow)"
			/>

			<g class="terrain-nodes">
				{
					nodes.map(({ x, y, kind }, index) => (
						<g class:list={['terrain-node', kind]} style={`--node-index:${index}`}>
							<circle cx={x} cy={y} r={kind === 'hot' ? 16 : 10} fill="url(#node-fill)" />
							<rect
								x={x - (kind === 'hot' ? 4 : 3)}
								y={y - (kind === 'hot' ? 4 : 3)}
								width={kind === 'hot' ? 8 : 6}
								height={kind === 'hot' ? 8 : 6}
								fill={kind === 'hot' ? '#fff5ee' : '#ff6a5f'}
								transform={`rotate(45 ${x} ${y})`}
							/>
						</g>
					))
				}
			</g>

			<g class="horizon-cluster" transform="translate(530 322)">
				<circle r="54" fill="none" stroke="#eb3f33" stroke-opacity="0.18" />
				<circle r="33" fill="none" stroke="#f4f1ec" stroke-opacity="0.14" stroke-dasharray="2 8" />
				<rect x="-7" y="-7" width="14" height="14" fill="#eb3f33" transform="rotate(45)" filter="url(#terrain-glow)" />
			</g>
		</svg>
	</div>

	<div class="hero-copy">
		<p class="hero-eyebrow">
			<span></span> Bifrost by <a href="https://brokk.ai" rel="external">Brokk</a>
			<b>Analyzer online</b>
		</p>
		<h1 id="_top" data-page-title>Code intelligence <em>for AI.</em></h1>
		<p class="hero-tagline">
			Give coding agents a structured model of the repository instead of another pile of text. Query
			symbols, trace usage graphs, and analyze large multi-language codebases locally.
		</p>
		{
			actions.length > 0 && (
				<div class="hero-actions">
					{actions.map(
						({ icon, link: href, text, variant }) => (
							<LinkButton href={href} variant={variant} icon={icon?.name}>
								{text}
								{icon?.html && <Fragment set:html={icon.html} />}
							</LinkButton>
						)
					)}
				</div>
			)
		}

		<ul class="hero-proof" aria-label="Core capabilities">
			<li><span>01</span><strong>Structural queries</strong><small>AST-aware matching</small></li>
			<li><span>02</span><strong>Usage graphs</strong><small>Definitions to call sites</small></li>
			<li><span>03</span><strong>Repository scale</strong><small>Multi-language context</small></li>
		</ul>
	</div>

	<div class="query-console" aria-hidden="true">
		<div class="console-topline">
			<span><i></i> QUERY / SYMBOL GRAPH</span>
			<small>RQL</small>
		</div>
		<code>(<b>call</b> :callee (<b>name</b> <span>"authenticate"</span>))</code>
		<div class="result-row primary"><i></i><span>AuthService.login</span><small>callsite</small></div>
		<div class="result-row"><i></i><span>SessionController.create</span><small>callsite</small></div>
		<div class="result-row"><i></i><span>TokenRefresh.run</span><small>callsite</small></div>
		<div class="console-foot"><span>3 structured results</span><span>NO TEXT FALLBACK</span></div>
	</div>
</section>

<style>
	@layer starlight.user {
		.bifrost-hero {
			position: relative;
			isolation: isolate;
			min-height: min(43rem, calc(100vh - var(--sl-nav-height) - 3rem));
			display: grid;
			align-items: center;
			padding: clamp(3.5rem, 8vw, 7.5rem) clamp(0rem, 2vw, 1.5rem) clamp(6rem, 13vw, 11rem);
			overflow: hidden;
		}

		.bifrost-hero::before {
			position: absolute;
			z-index: -1;
			inset: 6% auto auto 45%;
			width: 36rem;
			height: 36rem;
			border-radius: 50%;
			background: radial-gradient(circle, rgb(235 63 51 / 0.14), transparent 66%);
			content: '';
			filter: blur(6px);
		}

		.hero-copy {
			position: relative;
			z-index: 3;
			width: min(43rem, 64%);
		}

		.hero-eyebrow {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			margin: 0 0 1.5rem;
			color: #cbc4b7;
			font-family: var(--sl-font-mono);
			font-size: clamp(0.64rem, 0.8vw, 0.74rem);
			letter-spacing: 0.09em;
			text-transform: uppercase;
		}

		.hero-eyebrow > span {
			width: 0.5rem;
			height: 0.5rem;
			background: #eb3f33;
			box-shadow: 0 0 14px #eb3f33;
			transform: rotate(45deg);
		}

		.hero-eyebrow b {
			margin-inline-start: auto;
			color: #ff6a5f;
			font-size: 0.58rem;
			font-weight: 500;
		}

		.hero-eyebrow a {
			color: #f4f1ec;
			text-decoration-color: rgb(244 241 236 / 0.38);
			text-decoration-thickness: 1px;
			text-underline-offset: 0.2em;
			transition: color 140ms ease, text-decoration-color 140ms ease;
		}

		.hero-eyebrow a:hover,
		.hero-eyebrow a:focus-visible {
			color: #ff6a5f;
			text-decoration-color: currentColor;
		}

		h1 {
			max-width: 11ch;
			margin: 0;
			color: #f4f1ec;
			font-family: "Staatliches", "Brokk Docs Display", Impact, sans-serif;
			font-size: clamp(4.3rem, 9.2vw, 8.6rem);
			font-weight: 400;
			letter-spacing: -0.025em;
			line-height: 0.82;
			text-wrap: balance;
		}

		h1 em {
			display: block;
			color: #eb3f33;
			font-style: normal;
			text-shadow: 0 0 38px rgb(235 63 51 / 0.22);
		}

		.hero-tagline {
			max-width: 56ch;
			margin: clamp(1.5rem, 3vw, 2.2rem) 0 0;
			color: #cbc4b7;
			font-size: clamp(1.02rem, 1.55vw, 1.24rem);
			font-weight: 500;
			line-height: 1.52;
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-top: 1.8rem;
		}

		.hero-actions :global(a) {
			border-radius: 0.2rem;
			font-family: var(--sl-font-mono);
			font-size: 0.74rem;
			letter-spacing: 0.055em;
			text-transform: uppercase;
		}

		.hero-proof {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 0;
			max-width: 42rem;
			margin: 2.6rem 0 0;
			padding: 0;
			border-block: 1px solid rgb(255 255 255 / 0.1);
			list-style: none;
		}

		.hero-proof li {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 0.08rem 0.75rem;
			padding: 0.92rem 0.9rem 0.92rem 0;
		}

		.hero-proof li + li {
			padding-inline-start: 0.9rem;
			border-inline-start: 1px solid rgb(255 255 255 / 0.1);
		}

		.hero-proof span {
			grid-row: 1 / 3;
			align-self: center;
			color: #eb3f33;
			font-family: var(--sl-font-mono);
			font-size: 0.64rem;
		}

		.hero-proof strong,
		.hero-proof small {
			font-family: var(--sl-font-mono);
		}

		.hero-proof strong {
			color: #f4f1ec;
			font-size: 0.82rem;
			font-weight: 500;
		}

		.hero-proof small {
			color: #948b7e;
			font-size: 0.66rem;
		}

		.terrain-wrap {
			position: absolute;
			z-index: 0;
			inset: 0 -5% -4% 14%;
			pointer-events: none;
		}

		.terrain-halo {
			position: absolute;
			inset: 40% 0 0 15%;
			background: radial-gradient(ellipse at 58% 55%, rgb(235 63 51 / 0.16), transparent 50%);
			filter: blur(18px);
		}

		.semantic-terrain {
			width: 100%;
			height: 100%;
			overflow: visible;
		}

		.terrain-mesh path {
			stroke-width: 1;
			opacity: calc(0.38 + var(--line-index) * 0.04);
			vector-effect: non-scaling-stroke;
		}

		.terrain-ray {
			stroke-dasharray: 1 5;
		}

		.analysis-route {
			stroke-dasharray: 2 14;
			animation: route-flow 5s linear infinite;
			vector-effect: non-scaling-stroke;
		}

		.terrain-node {
			animation: node-breathe 3.6s ease-in-out infinite;
			animation-delay: calc(var(--node-index) * -0.38s);
			transform-box: fill-box;
			transform-origin: center;
		}

		.terrain-node.quiet {
			opacity: 0.56;
		}

		.horizon-cluster {
			animation: cluster-float 8s ease-in-out infinite;
			transform-box: fill-box;
			transform-origin: center;
		}

		.horizon-cluster circle:last-of-type {
			animation: cluster-spin 18s linear infinite;
			transform-box: fill-box;
			transform-origin: center;
		}

		.query-console {
			position: absolute;
			z-index: 4;
			inset-inline-end: 1.5%;
			inset-block-start: 16%;
			width: min(28rem, 34%);
			padding: 0.85rem;
			border: 1px solid rgb(255 255 255 / 0.13);
			border-radius: 0.35rem;
			background:
				linear-gradient(150deg, rgb(255 255 255 / 0.055), transparent 50%),
				rgb(8 8 8 / 0.82);
			box-shadow: 0 28px 70px rgb(0 0 0 / 0.46);
			backdrop-filter: blur(16px);
			transform: perspective(1000px) rotateY(-4deg) rotateX(1deg);
		}

		.console-topline,
		.console-foot,
		.result-row {
			display: flex;
			align-items: center;
		}

		.console-topline {
			justify-content: space-between;
			padding-bottom: 0.75rem;
			border-bottom: 1px solid rgb(255 255 255 / 0.09);
			color: #948b7e;
			font-family: var(--sl-font-mono);
			font-size: 0.57rem;
			letter-spacing: 0.08em;
		}

		.console-topline i {
			display: inline-block;
			width: 0.42rem;
			height: 0.42rem;
			margin-inline-end: 0.45rem;
			border-radius: 50%;
			background: #eb3f33;
			box-shadow: 0 0 9px #eb3f33;
		}

		.console-topline small {
			color: #ff6a5f;
		}

		.query-console code {
			display: block;
			margin: 0.75rem 0;
			padding: 0.72rem;
			border: 1px solid rgb(235 63 51 / 0.22);
			background: rgb(235 63 51 / 0.045);
			color: #cbc4b7;
			font-size: clamp(0.6rem, 0.8vw, 0.72rem);
			white-space: nowrap;
		}

		.query-console code b {
			color: #ff6a5f;
			font-weight: 500;
		}

		.query-console code span {
			color: #f4f1ec;
		}

		.result-row {
			gap: 0.6rem;
			padding: 0.55rem 0.4rem;
			border-top: 1px solid rgb(255 255 255 / 0.06);
			color: #948b7e;
			font-family: var(--sl-font-mono);
			font-size: clamp(0.55rem, 0.72vw, 0.68rem);
		}

		.result-row i {
			width: 0.36rem;
			height: 0.36rem;
			border: 1px solid currentColor;
			transform: rotate(45deg);
		}

		.result-row span {
			min-width: 0;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		.result-row small {
			margin-inline-start: auto;
			color: #5f5a52;
			text-transform: uppercase;
		}

		.result-row.primary {
			color: #f4f1ec;
		}

		.result-row.primary i {
			border-color: #eb3f33;
			background: #eb3f33;
			box-shadow: 0 0 8px rgb(235 63 51 / 0.6);
		}

		.console-foot {
			justify-content: space-between;
			padding: 0.7rem 0.4rem 0;
			color: #5f5a52;
			font-family: var(--sl-font-mono);
			font-size: 0.5rem;
			letter-spacing: 0.06em;
		}

		.console-foot span:last-child {
			color: #80615d;
		}

		@keyframes route-flow {
			to { stroke-dashoffset: -160; }
		}

		@keyframes node-breathe {
			0%, 100% { opacity: 0.5; transform: scale(0.82); }
			50% { opacity: 1; transform: scale(1.12); }
		}

		@keyframes cluster-float {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(-7px); }
		}

		@keyframes cluster-spin {
			to { transform: rotate(360deg); }
		}

		@media (max-width: 68rem) {
			.query-console {
				inset-block-start: 21%;
				width: 36%;
			}

			.hero-copy {
				width: 68%;
			}

			.hero-proof {
				max-width: 38rem;
			}
		}

		@media (max-width: 49.99rem) {
			.bifrost-hero {
				min-height: 41rem;
				align-items: start;
				padding-block: 3.5rem 10rem;
			}

			.hero-copy {
				width: 100%;
			}

			.hero-eyebrow b,
			.query-console {
				display: none;
			}

			.terrain-wrap {
				inset: 21% -42% -3% -20%;
				opacity: 0.78;
			}

			h1 {
				font-size: clamp(3.8rem, 17.2vw, 5.4rem);
				letter-spacing: -0.035em;
			}

			.hero-tagline {
				max-width: 42ch;
			}

			.hero-proof {
				grid-template-columns: 1fr;
				max-width: 22rem;
				margin-top: 2rem;
			}

			.hero-proof li,
			.hero-proof li + li {
				padding: 0.62rem 0;
				border-inline-start: 0;
			}

			.hero-proof li + li {
				border-top: 1px solid rgb(255 255 255 / 0.08);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.analysis-route,
			.terrain-node,
			.horizon-cluster,
			.horizon-cluster circle:last-of-type {
				animation: none;
			}

			.terrain-node {
				opacity: 0.86;
			}
		}
	}
</style>
